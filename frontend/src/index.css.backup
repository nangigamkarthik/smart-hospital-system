@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

/* ============================================
   IMPROVED HOSPITAL MANAGEMENT SYSTEM
   Better Contrast & Visibility
   ============================================ */

:root {
  /* Primary Colors - Teal/Cyan */
  --primary-50: #f0fdfa;
  --primary-100: #ccfbf1;
  --primary-200: #99f6e4;
  --primary-300: #5eead4;
  --primary-400: #2dd4bf;
  --primary-500: #14b8a6;
  --primary-600: #0d9488;
  --primary-700: #0f766e;
  --primary-800: #115e59;
  --primary-900: #134e4a;
  
  /* Secondary Colors - Purple/Violet */
  --secondary-500: #a855f7;
  --secondary-600: #9333ea;
  --secondary-700: #7e22ce;
  
  /* Accent Colors */
  --accent-500: #06b6d4;
  --accent-600: #0891b2;
  
  /* Status Colors */
  --success: #059669;
  --success-light: #d1fae5;
  --warning: #d97706;
  --warning-light: #fef3c7;
  --danger: #dc2626;
  --danger-light: #fee2e2;
  --info: #2563eb;
  --info-light: #dbeafe;
  
  /* IMPROVED Text Colors - Better Visibility */
  --text-primary: #0f172a;      /* Very dark blue-gray - Main text */
  --text-secondary: #334155;     /* Dark gray - Secondary text */
  --text-tertiary: #475569;      /* Medium gray - Tertiary text */
  --text-muted: #64748b;         /* Lighter gray - Muted text */
  --text-light: #94a3b8;         /* Light gray - Disabled text */
  
  /* Background Colors */
  --bg-primary: #ffffff;
  --bg-secondary: #f8fafc;
  --bg-tertiary: #f1f5f9;
  --bg-blue-light: #e0f2fe;
  --bg-teal-light: #f0fdfa;
  
  /* Border Colors */
  --border-light: #e2e8f0;
  --border-medium: #cbd5e1;
  --border-dark: #94a3b8;
  
  /* Shadows */
  --shadow-sm: 0 1px 2px 0 rgb(15 23 42 / 0.05);
  --shadow: 0 1px 3px 0 rgb(15 23 42 / 0.1), 0 1px 2px -1px rgb(15 23 42 / 0.1);
  --shadow-md: 0 4px 6px -1px rgb(15 23 42 / 0.1), 0 2px 4px -2px rgb(15 23 42 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(15 23 42 / 0.1), 0 4px 6px -4px rgb(15 23 42 / 0.1);
  --shadow-xl: 0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1);
  --shadow-2xl: 0 25px 50px -12px rgb(15 23 42 / 0.25);
}

/* ============================================
   RESET & BASE - IMPROVED
   ============================================ */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #f0fdfa 100%);
  min-height: 100vh;
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-weight: 400;
}

#root {
  min-height: 100vh;
}

/* Better text rendering */
h1, h2, h3, h4, h5, h6 {
  color: var(--text-primary);
  font-weight: 700;
  line-height: 1.3;
}

p {
  color: var(--text-secondary);
  line-height: 1.7;
}

a {
  color: var(--primary-600);
  text-decoration: none;
  font-weight: 500;
}

a:hover {
  color: var(--primary-700);
  text-decoration: underline;
}

/* ============================================
   SCROLLBAR - IMPROVED
   ============================================ */

::-webkit-scrollbar {
  width: 12px;
  height: 12px;
}

::-webkit-scrollbar-track {
  background: var(--bg-tertiary);
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
  border-radius: 10px;
  border: 2px solid var(--bg-tertiary);
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(135deg, #0d9488 0%, #0891b2 100%);
}

/* ============================================
   LAYOUT - IMPROVED
   ============================================ */

.app-layout {
  display: flex;
  min-height: 100vh;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 280px;
  transition: margin-left 0.3s ease;
}

.page-container {
  padding: 2rem;
  flex: 1;
  background: transparent;
}

/* ============================================
   NAVBAR - IMPROVED VISIBILITY
   ============================================ */

.navbar {
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 1px 3px 0 rgb(15 23 42 / 0.1), 0 1px 2px -1px rgb(15 23 42 / 0.1);
  border-bottom: 2px solid var(--border-light);
  position: sticky;
  top: 0;
  z-index: 40;
  backdrop-filter: blur(12px);
}

.navbar-content {
  padding: 1.25rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.navbar-title {
  font-size: 1.75rem;
  font-weight: 800;
  color: var(--text-primary);
  background: linear-gradient(135deg, #0d9488 0%, #0891b2 50%, #7e22ce 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.navbar-subtitle {
  font-size: 0.875rem;
  color: var(--text-muted);
  margin-top: 0.25rem;
  font-weight: 500;
}

.navbar-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.navbar-icon-button {
  padding: 0.625rem;
  border-radius: 0.75rem;
  border: none;
  background: var(--bg-tertiary);
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  color: var(--text-secondary);
}

.navbar-icon-button:hover {
  background: var(--bg-blue-light);
  color: var(--primary-700);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.navbar-icon-button svg {
  width: 20px;
  height: 20px;
}

.navbar-user {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.5rem 1rem;
  border-radius: 1rem;
  background: var(--bg-teal-light);
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1px solid var(--border-light);
}

.navbar-user:hover {
  background: var(--primary-100);
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary-300);
}

.navbar-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  box-shadow: var(--shadow-md);
  font-size: 1rem;
}

/* ============================================
   SIDEBAR - IMPROVED CONTRAST
   ============================================ */

.sidebar {
  width: 280px;
  background: var(--bg-primary);
  border-right: 1px solid var(--border-light);
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  overflow-y: auto;
  z-index: 50;
  box-shadow: 4px 0 6px -1px rgb(15 23 42 / 0.05);
}

.sidebar-header {
  padding: 2rem 1.5rem;
  border-bottom: 2px solid var(--border-light);
  background: var(--bg-teal-light);
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.sidebar-logo-icon {
  width: 48px;
  height: 48px;
  border-radius: 1rem;
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: var(--shadow-lg);
}

.sidebar-logo-text {
  font-size: 1.25rem;
  font-weight: 800;
  color: var(--text-primary);
}

.sidebar-nav {
  padding: 1.5rem 1rem;
}

.sidebar-section-title {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0 1rem;
  margin-bottom: 0.5rem;
  margin-top: 1.5rem;
}

.sidebar-section-title:first-child {
  margin-top: 0;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding: 0.875rem 1rem;
  margin: 0.25rem 0;
  border-radius: 0.875rem;
  color: var(--text-secondary);
  font-weight: 500;
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.sidebar-link::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
  transform: scaleY(0);
  transition: transform 0.3s ease;
}

.sidebar-link:hover {
  background: var(--bg-blue-light);
  color: var(--primary-700);
  transform: translateX(6px);
}

.sidebar-link:hover::before {
  transform: scaleY(1);
}

.sidebar-link.active {
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
  color: white;
  font-weight: 600;
  box-shadow: var(--shadow-md);
  transform: translateX(6px);
}

.sidebar-link.active::before {
  background: white;
  transform: scaleY(1);
}

.sidebar-link svg {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

/* ============================================
   BUTTONS - IMPROVED
   ============================================ */

button {
  font-family: inherit;
}

.btn {
  padding: 0.75rem 1.5rem;
  border-radius: 0.75rem;
  border: none;
  font-weight: 600;
  font-size: 0.9375rem;
  cursor: pointer;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  justify-content: center;
  text-decoration: none;
  box-shadow: var(--shadow);
  color: var(--text-primary);
}

.btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn:active {
  transform: translateY(0);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
}

.btn-primary {
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
  color: white;
  font-weight: 600;
}

.btn-primary:hover {
  background: linear-gradient(135deg, #0d9488 0%, #0891b2 100%);
}

.btn-secondary {
  background: white;
  color: var(--primary-700);
  border: 2px solid var(--primary-300);
  font-weight: 600;
}

.btn-secondary:hover {
  background: var(--bg-teal-light);
  border-color: var(--primary-500);
  color: var(--primary-800);
}

.btn-success {
  background: linear-gradient(135deg, #059669 0%, #14b8a6 100%);
  color: white;
  font-weight: 600;
}

.btn-danger {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  color: white;
  font-weight: 600;
}

.btn-purple {
  background: linear-gradient(135deg, #9333ea 0%, #c026d3 100%);
  color: white;
  font-weight: 600;
}

.btn-sm {
  padding: 0.5rem 1rem;
  font-size: 0.875rem;
}

.btn-lg {
  padding: 1rem 2rem;
  font-size: 1.0625rem;
}

/* ============================================
   CARDS - IMPROVED CONTRAST
   ============================================ */

.card {
  background: white;
  border-radius: 1.25rem;
  padding: 1.5rem;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border-light);
  transition: all 0.3s ease;
}

.card:hover {
  box-shadow: var(--shadow-xl);
  transform: translateY(-4px);
  border-color: var(--border-medium);
}

.card-header {
  padding-bottom: 1rem;
  margin-bottom: 1rem;
  border-bottom: 2px solid var(--border-light);
}

.card-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* ============================================
   STAT CARDS - IMPROVED
   ============================================ */

.stat-card {
  border-radius: 1.5rem;
  padding: 2rem;
  color: white;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.stat-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  animation: pulse 3s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.stat-card:hover {
  transform: translateY(-6px) scale(1.02);
  box-shadow: var(--shadow-2xl);
}

.stat-card-blue {
  background: linear-gradient(135deg, #2563eb 0%, #0891b2 100%);
}

.stat-card-purple {
  background: linear-gradient(135deg, #9333ea 0%, #db2777 100%);
}

.stat-card-green {
  background: linear-gradient(135deg, #059669 0%, #14b8a6 100%);
}

.stat-card-orange {
  background: linear-gradient(135deg, #ea580c 0%, #dc2626 100%);
}

.stat-card-teal {
  background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);
}

.stat-card-content {
  position: relative;
  z-index: 1;
}

.stat-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1rem;
}

.stat-card-icon {
  width: 56px;
  height: 56px;
  border-radius: 1rem;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 16px -4px rgb(0 0 0 / 0.2);
}

.stat-card-icon svg {
  width: 28px;
  height: 28px;
}

.stat-card-label {
  font-size: 0.875rem;
  opacity: 0.95;
  font-weight: 600;
  text-shadow: 0 1px 2px rgb(0 0 0 / 0.1);
}

.stat-card-value {
  font-size: 2.5rem;
  font-weight: 800;
  line-height: 1;
  margin: 0.75rem 0;
  text-shadow: 0 2px 4px rgb(0 0 0 / 0.1);
}

.stat-card-change {
  font-size: 0.875rem;
  opacity: 0.9;
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-weight: 500;
}

/* ============================================
   TABLES - IMPROVED READABILITY
   ============================================ */

.table-container {
  background: white;
  border-radius: 1.25rem;
  overflow: hidden;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--border-light);
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.table thead {
  background: linear-gradient(135deg, #0d9488 0%, #0891b2 100%);
}

.table th {
  padding: 1.25rem 1.5rem;
  text-align: left;
  font-weight: 700;
  font-size: 0.875rem;
  color: white;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  text-shadow: 0 1px 2px rgb(0 0 0 / 0.1);
}

.table td {
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border-light);
  color: var(--text-secondary);
  font-size: 0.9375rem;
  font-weight: 500;
}

.table tbody tr {
  transition: all 0.2s ease;
  background: white;
}

.table tbody tr:hover {
  background: var(--bg-blue-light);
  transform: scale(1.01);
  box-shadow: 0 2px 4px -1px rgb(15 23 42 / 0.05);
}

.table tbody tr:last-child td {
  border-bottom: none;
}

/* ============================================
   FORMS - IMPROVED VISIBILITY
   ============================================ */

.form-group {
  margin-bottom: 1.5rem;
}

.form-label {
  display: block;
  font-weight: 600;
  font-size: 0.9375rem;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.form-input,
.form-select,
.form-textarea {
  width: 100%;
  padding: 0.875rem 1rem;
  border: 2px solid var(--border-medium);
  border-radius: 0.75rem;
  font-size: 1rem;
  font-family: inherit;
  transition: all 0.3s ease;
  background: white;
  color: var(--text-primary);
  font-weight: 500;
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: var(--text-light);
  font-weight: 400;
}

.form-input:focus,
.form-select:focus,
.form-textarea:focus {
  outline: none;
  border-color: var(--primary-500);
  box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.15);
  transform: translateY(-1px);
}

.form-input:hover,
.form-select:hover,
.form-textarea:hover {
  border-color: var(--primary-400);
}

.form-textarea {
  resize: vertical;
  min-height: 120px;
}

.form-error {
  color: var(--danger);
  font-size: 0.875rem;
  margin-top: 0.5rem;
  font-weight: 500;
}

/* ============================================
   BADGES - IMPROVED CONTRAST
   ============================================ */

.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.375rem 0.875rem;
  border-radius: 9999px;
  font-size: 0.8125rem;
  font-weight: 700;
  box-shadow: var(--shadow-sm);
  border: 1px solid transparent;
}

.badge-primary {
  background: var(--primary-100);
  color: var(--primary-900);
  border-color: var(--primary-200);
}

.badge-success {
  background: var(--success-light);
  color: #065f46;
  border-color: #86efac;
}

.badge-warning {
  background: var(--warning-light);
  color: #92400e;
  border-color: #fde68a;
}

.badge-danger {
  background: var(--danger-light);
  color: #991b1b;
  border-color: #fecaca;
}

.badge-info {
  background: var(--info-light);
  color: #1e40af;
  border-color: #bfdbfe;
}

.badge-purple {
  background: #f3e8ff;
  color: #6b21a8;
  border-color: #e9d5ff;
}

/* ============================================
   MODALS - IMPROVED
   ============================================ */

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease-out;
}

.modal-content {
  background: white;
  border-radius: 1.5rem;
  box-shadow: var(--shadow-2xl);
  max-width: 90vw;
  max-height: 90vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease-out;
  border: 1px solid var(--border-light);
}

.modal-header {
  padding: 1.5rem 2rem;
  border-bottom: 2px solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-teal-light);
  border-top-left-radius: 1.5rem;
  border-top-right-radius: 1.5rem;
}

.modal-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-body {
  padding: 2rem;
}

.modal-footer {
  padding: 1.5rem 2rem;
  border-top: 2px solid var(--border-light);
  display: flex;
  gap: 1rem;
  justify-content: flex-end;
  background: var(--bg-secondary);
  border-bottom-left-radius: 1.5rem;
  border-bottom-right-radius: 1.5rem;
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ============================================
   UTILITY CLASSES - IMPROVED
   ============================================ */

/* Text Colors */
.text-primary { color: var(--text-primary) !important; }
.text-secondary { color: var(--text-secondary) !important; }
.text-tertiary { color: var(--text-tertiary) !important; }
.text-muted { color: var(--text-muted) !important; }
.text-white { color: white !important; }

/* Spacing */
.p-4 { padding: 1rem; }
.p-6 { padding: 1.5rem; }
.p-8 { padding: 2rem; }
.m-4 { margin: 1rem; }
.mb-4 { margin-bottom: 1rem; }
.mb-6 { margin-bottom: 1.5rem; }
.mt-4 { margin-top: 1rem; }

/* Flexbox */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.gap-4 { gap: 1rem; }
.gap-6 { gap: 1.5rem; }

/* Grid */
.grid { display: grid; }
.grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
.grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

/* Text Styling */
.text-center { text-align: center; }
.text-sm { font-size: 0.875rem; }
.text-lg { font-size: 1.125rem; }
.text-xl { font-size: 1.25rem; }
.text-2xl { font-size: 1.5rem; }
.text-3xl { font-size: 1.875rem; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* Display */
.hidden { display: none; }
.block { display: block; }
.w-full { width: 100%; }
.cursor-pointer { cursor: pointer; }

/* Loading Spinner */
.loading-spinner {
  width: 3rem;
  height: 3rem;
  border: 4px solid var(--border-light);
  border-top-color: var(--primary-600);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* ============================================
   PAGE SPECIFIC - IMPROVED
   ============================================ */

.page-header {
  margin-bottom: 2rem;
}

.page-title {
  font-size: 2rem;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.page-subtitle {
  color: var(--text-muted);
  font-size: 1rem;
  font-weight: 500;
}

.page-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  align-items: center;
}

/* Dashboard */
.dashboard-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.dashboard-charts {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

/* Table Actions */
.table-actions {
  display: flex;
  gap: 0.5rem;
}

.action-btn {
  padding: 0.5rem;
  border-radius: 0.5rem;
  border: none;
  background: var(--bg-tertiary);
  cursor: pointer;
  transition: all 0.2s ease;
  color: var(--text-secondary);
}

.action-btn:hover {
  transform: scale(1.1);
}

.action-btn-view {
  color: var(--info);
}

.action-btn-view:hover {
  background: var(--info-light);
}

.action-btn-edit {
  color: var(--primary-700);
}

.action-btn-edit:hover {
  background: var(--bg-teal-light);
}

.action-btn-delete {
  color: var(--danger);
}

.action-btn-delete:hover {
  background: var(--danger-light);
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 4rem 2rem;
}

.empty-state-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 1.5rem;
  opacity: 0.4;
  color: var(--text-muted);
}

.empty-state-title {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.empty-state-message {
  color: var(--text-muted);
  margin-bottom: 1.5rem;
  font-weight: 500;
}

/* ============================================
   RESPONSIVE
   ============================================ */

@media (max-width: 1024px) {
  .sidebar {
    transform: translateX(-100%);
  }
  .main-content {
    margin-left: 0;
  }
}

@media (max-width: 768px) {
  .grid-cols-2,
  .grid-cols-3,
  .grid-cols-4 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }
  .page-container {
    padding: 1rem;
  }
  .navbar-content {
    padding: 1rem;
  }
  .stat-card {
    padding: 1.5rem;
  }
  .stat-card-value {
    font-size: 2rem;
  }
}

/* ============================================
   IMPROVED FOCUS STATES
   ============================================ */

button:focus-visible,
a:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline: 2px solid var(--primary-500);
  outline-offset: 2px;
}

/* ============================================
   IMPROVED TRANSITIONS
   ============================================ */

.transition-all { transition: all 0.3s ease; }
.transition-colors { transition: color 0.3s ease, background-color 0.3s ease, border-color 0.3s ease; }
.transition-transform { transition: transform 0.3s ease; }
